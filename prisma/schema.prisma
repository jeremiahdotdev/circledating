generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum Gender {
  MALE
  FEMALE
}

enum Children {
  HAS_AND_WANTS
  HAS_AND_DOES_NOT_WANT
  HAS_NOT_AND_DOES_NOT_WANT
  HAS_NOT_AND_DOES_WANT
}

enum Ethnicity {
  WHITE
  BLACK_OR_AFRICAN_AMERICAN
  AMERICAN_INDIAN_OR_ALASKA_NATIVE
  ASIAN
  NATIVE_HAWAIIAN_OR_OTHER_PACIFIC_ISLANDER
  OTHER
}

enum Drinking {
  INFREQUENT
  MILD
  SOCIAL
  FREQUENT
  HEAVY
  NEVER
}

enum Consumables {
  SMOKING
  VAPING
  OCCASIONAL_CIGARS
  EDIBLES_GUMMIES
  NO_CONSUMABLES
}

enum PoliticalBeliefs {
  CONSERVATIVE
  CONSERVATIVE_LEANING_MODERATE
  MODERATE
  LIBERAL_LEANING_MODERATE
  LIBERAL
  INDEPENDENT
  APOLITICAL
}

enum LevelOfEducation {
  DOCTORATE
  MASTERS
  BACHELORS
  ASSOCIATES
  HIGH_SCHOOL
  NO_DEGREE
}

enum Purity {
  VIRGIN_WAITING
  NOT_VIRGIN_WAITING
  VIRGIN_NOT_WAITING
  NOT_VIRGIN_NOT_WAITING
}

enum Income {
  SINGLE
  DUAL
  EITHER
}

enum MaritalStatus {
  NEVER_MARRIED
  WIDOWED
  DIVORCED
}

enum Activity {
  INFREQUENT
  MILD
  FREQUENT
  HEAVY
  NEVER
}

enum Religion {
  AGNOSTICISM
  ATHEISM
  BUDDHISM
  CHRISTIANITY
  HINDUISM
  JUDAISM
  MORMONISM
  OTHER
}

enum WeightUnit {
  LBS
  KG
}

enum YesNoOrUnknown {
  YES
  NO
  UNKNOWN
}

enum UserType {
  CIRCLE_MOD
  CIRCLE_OWNER
  PLEB
}

model Location {
  id          String        @id @default(uuid())
  continent   String
  country     String
  state       String?
  UserProfile UserProfile[]
}

model UserProfile {
  userId          					 String           @id @default(uuid())
  username                           String           @unique
  image                              String?           
  sex                                Gender
  birthDate                          DateTime
  height                             Int?
  weight                             Float?
  locationId                         String
  location                           Location         @relation(fields: [locationId], references: [id])
  willingToRelocate                  YesNoOrUnknown
  children                           Children
  ethnicity                          Ethnicity
  drinking                           Drinking
  consumables                        Consumables
  politicalBeliefs                   PoliticalBeliefs
  levelOfEducation                   LevelOfEducation
  purity                             Purity?
  income                             Income
  maritalStatus                      MaritalStatus
  activity                           Activity
  religion                           Religion
  bio                                String          @db.LongText
  weightUnit                         WeightUnit
  User                               User[] @relation("userProfile")
  circles             				 UserCircle[]
  interactions  	  			     UserInteraction[]    	@relation("userInteractions") 
  affections    	  			     UserInteraction[]    	@relation("userAffections") 
  links         					 Json?       

  @@index([locationId])
}

model UserCircle {
  id          String        @id @default(uuid())
  circleTitle UserType      @default(PLEB)
  circleId    String
  Circle      Circle        @relation(fields: [circleId], references: [id])
  userId      String 
  User        UserProfile   @relation(fields: [userId], references: [userId])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime?     @updatedAt

  @@index([userId])
  @@index([circleId])
}

model Circle {
  id         									String        						@id @default(uuid())
  name                                          String                              @unique
  label                                         String                              @unique
  image                                         String?           
  description                                   String                              @db.LongText            
  isFeatured									Boolean                             @default(false)
  isPrivate 									Boolean                             @default(false)
  code         									String        						@unique @default(uuid())
  ageMaxRestriction                             Int?
  ageMinRestriction                             Int?
  maxWeightRestriction                          Int?
  sexRestriction                                Json?
  countryRestriction                            Json?
  childrenRestriction                           Json?
  ethnicityRestriction                          Json?
  drinkingRestriction                           Json?
  consumablesRestriction                        Json?
  politicalBeliefsRestriction                   Json?
  levelOfEducationRestriction                   Json?
  purityRestriction                             Json?
  incomeRestriction                             Json?
  maritalStatusRestriction                      Json?
  activityRestriction                           Json?
  religionRestriction                           Json?
  users                                         UserCircle[]
  selected                                      SelectedCircle[]
  links         					            Json?
  requests										CircleRequest[]     
  reports										UserReport[]     
  createdAt           							DateTime     						@default(now())
  updatedAt           							DateTime?    						@updatedAt
  @@index([name])
}
model User {
  id                  String       			@id @default(uuid())
  email               String       			@unique
  password            String
  profile             UserProfile?			@relation("userProfile", fields: [username], references: [username],  map: "user_profile_fk")
  createdAt           DateTime     			@default(now())
  updatedAt           DateTime?    			@updatedAt
  username			  String       			@unique
  isAdmin			  Boolean       	    @default(false)
  preferences         UserPreferences?
  authoredMessages    UserMessage[]    		@relation("authoredMessages") 
  recievedMessages    UserMessage[]    		@relation("recievedMessages")
  authoredReports     UserReport[]    		@relation("authoredReports") 
  recievedReports     UserReport[]    		@relation("recievedReports")
  authoredRequests    CircleRequest[]       
  conversations       UserConversation[]         
  @@index([username])
}

model UserPreferences {
  userId              String       @unique
  user                User         @relation(fields: [userId], references: [id])
  minAge              Int
  maxAge              Int
  sex                 Gender?
  selectedCircles     SelectedCircle[]
  searchContinents    Json?
  searchCountries     Json?
  searchStates        Json?
  children			  Json?
  ethnicity           Json?
  drinking            Json?
  consumables         Json?
  politicalBeliefs    Json?
  levelOfEducation    Json?
  purity              Json?
  income              Json?
  maritalStatus       Json?
  activity            Json?
  religion            Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime?    @updatedAt

  @@index([userId])
}

model SelectedCircle {
  id         String            @id @default(uuid())
  circleId   String
  Circle     Circle            @relation(fields: [circleId], references: [id])
  userId     String 
  User       UserPreferences   @relation(fields: [userId], references: [userId])

  @@index([userId])
  @@index([circleId])
}

model UserInteraction {
  id                  String       @id @default(uuid())
  initiatedUserId     String    
  initiatedUser       UserProfile         @relation("userInteractions", fields: [initiatedUserId], references: [userId],  map: "user_initiated_fk")
  affectedUserId      String  
  affectedUser        UserProfile         @relation("userAffections", fields: [affectedUserId], references: [userId],  map: "user_affected_fk")
  isLiked 			  Boolean
  isBlocked			  Boolean

  @@index([initiatedUserId])
  @@index([affectedUserId])
}

model UserMessage {
  id                  String        @id @default(uuid())
  conversationId      String?       @default(uuid())
  conversation        Conversation? @relation(fields: [conversationId], references: [id])
  authorUsername      String    
  author              User          @relation("authoredMessages", fields: [authorUsername], references: [username],  map: "user_author_fk")
  recipientUsername   String  
  recipient           User          @relation("recievedMessages", fields: [recipientUsername], references: [username],  map: "user_recipient_fk")
  content             String        @db.LongText
  isRead			  Boolean	    @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime?     @updatedAt

  @@index([conversationId])
  @@index([authorUsername])
  @@index([recipientUsername])
}

model UserReport {
  id                  String       @id @default(uuid())
  reporterUsername    String    
  reporter            User         @relation("authoredReports", fields: [reporterUsername], references: [username],  map: "user_report_author_fk")
  reportedUsername    String  
  reportedUser        User         @relation("recievedReports", fields: [reportedUsername], references: [username],  map: "user_report_recipient_fk")
  circleId            String?
  circle              Circle?      @relation(fields: [circleId], references: [id])
  message             String       @db.LongText
  createdAt           DateTime     @default(now())
  updatedAt           DateTime?    @updatedAt

  @@index([circleId])
  @@index([reporterUsername])
  @@index([reportedUsername])
}

model Conversation {
  id                  String       		@id @default(uuid())
  users               UserConversation[] 
  messages            UserMessage[]
  createdAt           DateTime     		@default(now())
  updatedAt           DateTime?    		@updatedAt
  deletedAt           DateTime?    		
}

model UserConversation {
  id                  String         @id @default(uuid())
  userId              String       
  conversationId      String         
  user                User 		     @relation(fields: [userId], references: [id])
  conversation        Conversation   @relation(fields: [conversationId], references: [id])

  @@index([userId])
  @@index([conversationId])
}

model CircleRequest {
  id                  String         @id @default(uuid())
  circleId            String
  userId              String
  message             String         
  author              User           @relation(fields: [userId], references: [id])
  circle              Circle         @relation(fields: [circleId], references: [id])  
  createdAt           DateTime       @default(now())
  updatedAt           DateTime?      @updatedAt

  @@index([circleId])    
  @@index([userId])    
}