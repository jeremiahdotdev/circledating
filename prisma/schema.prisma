generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum Gender {
  MALE
  FEMALE
}

enum Children {
  HAS_AND_WANTS
  HAS_AND_DOES_NOT_WANT
  HAS_NOT_AND_DOES_NOT_WANT
  HAS_NOT_AND_DOES_WANT
}

enum Ethnicity {
  WHITE
  BLACK_OR_AFRICAN_AMERICAN
  AMERICAN_INDIAN_OR_ALASKA_NATIVE
  ASIAN
  NATIVE_HAWAIIAN_OR_OTHER_PACIFIC_ISLANDER
  OTHER
}

enum Drinking {
  INFREQUENT
  MILD
  SOCIAL
  FREQUENT
  HEAVY
  NEVER
}

enum Consumables {
  SMOKING
  VAPING
  OCCASIONAL_CIGARS
  EDIBLES_GUMMIES
  NO_CONSUMABLES
}

enum PoliticalBeliefs {
  CONSERVATIVE
  CONSERVATIVE_LEANING_MODERATE
  MODERATE
  LIBERAL_LEANING_MODERATE
  LIBERAL
  INDEPENDENT
  APOLITICAL
}

enum LevelOfEducation {
  DOCTORATE
  MASTERS
  BACHELORS
  ASSOCIATES
  HIGH_SCHOOL
  NO_DEGREE
}

enum Purity {
  VIRGIN_WAITING
  NOT_VIRGIN_WAITING
  VIRGIN_NOT_WAITING
  NOT_VIRGIN_NOT_WAITING
  PURITY_UNKNOWN
}

enum Income {
  SINGLE
  DUAL
  EITHER
}

enum MaritalStatus {
  NEVER_MARRIED
  WIDOWED
  DIVORCED
}

enum Activity {
  INFREQUENT
  MILD
  FREQUENT
  HEAVY
  NEVER
}

enum Religion {
  AGNOSTICISM
  ATHEISM
  BUDDHISM
  CHRISTIANITY
  HINDUISM
  JUDAISM
  MORMONISM
  OTHER
}

enum WeightUnit {
  LBS
  KG
}

enum YesNoOrUnknown {
  YES
  NO
  UNKNOWN
}

model Location {
  id          String        @id @default(uuid())
  continent   String
  country     String
  state       String
  UserProfile UserProfile[]
}

model UserProfile {
  userId          					 String           @id @default(uuid())
  username                           String           @unique
  sex                                Gender
  birthDate                          DateTime
  height                             Int
  weight                             Float
  locationId                         String
  location                           Location         @relation(fields: [locationId], references: [id])
  willingToRelocate                  YesNoOrUnknown
  children                           Children
  ethnicity                          Ethnicity
  drinking                           Drinking
  consumables                        Consumables
  politicalBeliefs                   PoliticalBeliefs
  levelOfEducation                   LevelOfEducation
  purity                             Purity
  onlyLookingForTraditionalHousehold YesNoOrUnknown
  income                             Income
  maritalStatus                      MaritalStatus
  activity                           Activity
  religion                           Religion
  bio                                String?          @db.LongText
  weightUnit                         WeightUnit
  User                               User[] @relation("userProfile")
  circles             				 UserCircle[]
  userInteractions  	  			 UserInteraction[]    	@relation("userInteractions") 
  userAffections    	  			 UserInteraction[]    	@relation("userAffections") 

  @@index([locationId])
}

model UserCircle {
  id         String        @id @default(uuid())
  circleId   String
  Circle     Circle        @relation(fields: [circleId], references: [id])
  userId     String 
  User       UserProfile   @relation(fields: [userId], references: [userId])

  @@index([userId])
  @@index([circleId])
}

model Circle {
  id         									String        						@id @default(uuid())
  name                                          String                              @unique
  label                                         String                              @unique
  sexRestriction                                CircleSexRestriction[]
  ageMaxRestriction                             Int?
  ageMinRestriction                             Int?
  maxWeightRestriction                          Int?
  continentRestriction                          CircleContinentRestriction[]
  willingToRelocateRestriction                  CircleRelocationRestriction[]
  childrenRestriction                           CircleChildrenRestriction[]
  ethnicityRestriction                          CircleEthnicityRestriction[]
  drinkingRestriction                           CircleDrinkingRestriction[]
  consumablesRestriction                        CircleConsumablesRestriction[]
  politicalBeliefsRestriction                   CirclePoliticalBeliefsRestriction[]
  levelOfEducationRestriction                   CircleLevelOfEducationRestriction[]
  purityRestriction                             CirclePurityRestriction[]
  onlyLookingForTraditionalHouseholdRestriction CircleTraditionalRestriction[]
  incomeRestriction                             CircleIncomeRestriction[]
  maritalStatusRestriction                      CircleMaritalStatusRestriction[]
  activityRestriction                           CircleActivityRestriction[]
  religionRestriction                           CircleReligionRestriction[]
  users                                         UserCircle[]
  selected                                      SelectedCircle[]

  @@index([name])
}

model CircleContinentRestriction {
  id          String    @id @default(uuid())
  circleId  String
  circle      Circle    @relation(fields: [circleId], references: [id])
  restriction String

  @@index([circleId])
}

model CircleSexRestriction {
  id          String @id @default(uuid())
  circleId  String
  circle      Circle @relation(fields: [circleId], references: [id])
  restriction Gender

  @@index([circleId])
}

model CircleRelocationRestriction {
  id          String         @id @default(uuid())
  circleId  String
  circle      Circle         @relation(fields: [circleId], references: [id])
  restriction YesNoOrUnknown

  @@index([circleId])
}

model CircleChildrenRestriction {
  id          String   @id @default(uuid())
  circleId  String
  circle      Circle   @relation(fields: [circleId], references: [id])
  restriction Children

  @@index([circleId])
}

model CircleEthnicityRestriction {
  id          String    @id @default(uuid())
  circleId  String
  circle      Circle    @relation(fields: [circleId], references: [id])
  restriction Ethnicity

  @@index([circleId])
}

model CircleDrinkingRestriction {
  id          String   @id @default(uuid())
  circleId  String
  circle      Circle   @relation(fields: [circleId], references: [id])
  restriction Drinking

  @@index([circleId])
}

model CircleConsumablesRestriction {
  id          String      @id @default(uuid())
  circleId  String
  circle      Circle      @relation(fields: [circleId], references: [id])
  restriction Consumables

  @@index([circleId])
}

model CirclePoliticalBeliefsRestriction {
  id          String           @id @default(uuid())
  circleId  String
  circle      Circle           @relation(fields: [circleId], references: [id])
  restriction PoliticalBeliefs

  @@index([circleId])
}

model CircleLevelOfEducationRestriction {
  id          String           @id @default(uuid())
  circleId  String
  circle      Circle           @relation(fields: [circleId], references: [id])
  restriction LevelOfEducation

  @@index([circleId])
}

model CirclePurityRestriction {
  id          String           @id @default(uuid())
  circleId  String
  circle      Circle           @relation(fields: [circleId], references: [id])
  restriction Purity

  @@index([circleId])
}

model CircleTraditionalRestriction {
  id          String         @id @default(uuid())
  circleId  String
  circle      Circle         @relation(fields: [circleId], references: [id])
  restriction YesNoOrUnknown

  @@index([circleId])
}

model CircleIncomeRestriction {
  id          String @id @default(uuid())
  circleId  String
  circle      Circle @relation(fields: [circleId], references: [id])
  restriction Income

  @@index([circleId])
}

model CircleMaritalStatusRestriction {
  id          String        @id @default(uuid())
  circleId  String
  circle      Circle        @relation(fields: [circleId], references: [id])
  restriction MaritalStatus

  @@index([circleId])
}

model CircleActivityRestriction {
  id          String   @id @default(uuid())
  circleId  String
  circle      Circle   @relation(fields: [circleId], references: [id])
  restriction Activity

  @@index([circleId])
}

model CircleReligionRestriction {
  id          String   @id @default(uuid())
  circleId  String
  circle      Circle   @relation(fields: [circleId], references: [id])
  restriction Religion

  @@index([circleId])
}

model User {
  id                  String       			@id @default(uuid())
  email               String       			@unique
  password            String
  profile             UserProfile  			@relation("userProfile", fields: [username], references: [username],  map: "user_profile_fk")
  createdAt           DateTime     			@default(now())
  updatedAt           DateTime?    			@updatedAt
  username			  String       			@unique
  preferences         UserPreferences[]
  authoredMessages    UserMessage[]    		@relation("authoredMessages") 
  recievedMessages    UserMessage[]    		@relation("recievedMessages")
  conversations       UserConversation[]         

  @@index([username])
}

model UserPreferences {
  userId              String       @unique
  user                User         @relation(fields: [userId], references: [id])
  minAge              Int
  maxAge              Int
  sex                 Gender?
  circles             SelectedCircle[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime?    @updatedAt

  @@index([userId])
}

model SelectedCircle {
  id         String            @id @default(uuid())
  circleId   String
  Circle     Circle            @relation(fields: [circleId], references: [id])
  userId   String 
  User       UserPreferences   @relation(fields: [userId], references: [userId])

  @@index([userId])
  @@index([circleId])
}



model UserInteraction {
  id                  String       @id @default(uuid())
  initiatedUserId     String    
  initiatedUser       UserProfile         @relation("userInteractions", fields: [initiatedUserId], references: [userId],  map: "user_initiated_fk")
  affectedUserId      String  
  affectedUser        UserProfile         @relation("userAffections", fields: [affectedUserId], references: [userId],  map: "user_affected_fk")
  isLiked 			  Boolean
  isBlocked			  Boolean

  @@index([initiatedUserId])
  @@index([affectedUserId])
}

model UserMessage {
  id                  String       @id @default(uuid())
  conversationId      String?       @default(uuid())
  conversation        Conversation? @relation(fields: [conversationId], references: [id])
  authorUsername      String    
  author              User         @relation("authoredMessages", fields: [authorUsername], references: [username],  map: "user_author_fk")
  recipientUsername   String  
  recipient           User         @relation("recievedMessages", fields: [recipientUsername], references: [username],  map: "user_recipient_fk")
  content             String       @db.VarChar(2000) 
  createdAt           DateTime     @default(now())
  updatedAt           DateTime?    @updatedAt

  @@index([conversationId])
  @@index([authorUsername])
  @@index([recipientUsername])
}
model Conversation {
  id                  String       		@id @default(uuid())
  users               UserConversation[] 
  messages            UserMessage[]
  createdAt           DateTime     		@default(now())
  updatedAt           DateTime?    		@updatedAt
}

model UserConversation {
  id                  String         @id @default(uuid())
  userId              String       
  conversationId      String         
  user                User 		     @relation(fields: [userId], references: [id])
  conversation        Conversation   @relation(fields: [conversationId], references: [id])

  @@index([userId])
  @@index([conversationId])
}