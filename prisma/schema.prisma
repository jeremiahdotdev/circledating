generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

enum Gender {
  MALE
  FEMALE
}

enum Children {
  HAS_AND_WANTS
  HAS_AND_DOES_NOT_WANT
  HAS_NOT_AND_DOES_NOT_WANT
  HAS_NOT_AND_DOES_WANT
}

enum Ethnicity {
  WHITE
  BLACK_OR_AFRICAN_AMERICAN
  AMERICAN_INDIAN_OR_ALASKA_NATIVE
  ASIAN
  NATIVE_HAWAIIAN_OR_OTHER_PACIFIC_ISLANDER
  OTHER
}

enum Drinking {
  INFREQUENT
  MILD
  SOCIAL
  FREQUENT
  HEAVY
  NEVER
}

enum Consumables {
  SMOKING
  VAPING
  OCCASIONAL_CIGARS
  EDIBLES_GUMMIES
  NO_CONSUMABLES
}

enum Continent {
  NORTH_AMERICA
  SOUTH_AMERICA
  AFRICA
  ASIA
  EUROPE
  ANTARTICA
  AUSTRALIA
}

enum PoliticalBeliefs {
  CONSERVATIVE
  CONSERVATIVE_LEANING_MODERATE
  MODERATE
  LIBERAL_LEANING_MODERATE
  LIBERAL
  INDEPENDENT
  APOLITICAL
}

enum LevelOfEducation {
  DOCTORATE
  MASTERS
  BACHELORS
  ASSOCIATES
  HIGH_SCHOOL
  NO_DEGREE
}

enum Purity {
  VIRGIN_WAITING
  NOT_VIRGIN_WAITING
  VIRGIN_NOT_WAITING
  NOT_VIRGIN_NOT_WAITING
  PURITY_UNKNOWN
}

enum Income {
  SINGLE
  DUAL
  EITHER
}

enum MaritalStatus {
  NEVER_MARRIED
  WIDOWED
  DIVORCED
}

enum Activity {
  INFREQUENT
  MILD
  FREQUENT
  HEAVY
  NEVER
}

enum Religion {
  AGNOSTICISM
  ATHEISM
  BUDDHISM
  CHRISTIANITY
  HINDUISM
  JUDAISM
  MORMONISM
  OTHER
}

enum WeightUnit {
  LBS
  KG
}

enum YesNoOrUnknown {
  YES
  NO
  UNKNOWN
}

model Location {
  id          String        @id @default(uuid())
  country     String
  state       String
  UserProfile UserProfile[]
}

model UserProfile {
  username                           String           @unique
  sex                                Gender
  birthDate                          DateTime
  height                             Int
  weight                             Float
  locationId                         String
  continent                          Continent
  location                           Location         @relation(fields: [locationId], references: [id])
  willingToRelocate                  YesNoOrUnknown
  children                           Children
  ethnicity                          Ethnicity
  drinking                           Drinking
  consumables                        Consumables
  politicalBeliefs                   PoliticalBeliefs
  levelOfEducation                   LevelOfEducation
  purity                             Purity
  onlyLookingForTraditionalHousehold YesNoOrUnknown
  income                             Income
  maritalStatus                      MaritalStatus
  activity                           Activity
  religion                           Religion
  bio                                String?          @db.LongText
  weightUnit                         WeightUnit
  User                               User[]

  @@index([locationId])
}

model UserCircle {
  circleName String @unique
  Circle     Circle @relation(fields: [circleName], references: [name])
  username   String @unique
  User       User   @relation(fields: [username], references: [userCircleUsername])
}

model Circle {
  name                                          String                              @unique
  label                                         String                              @unique
  sexRestriction                                CircleSexRestriction[]
  ageMaxRestriction                             Int?
  ageMinRestriction                             Int?
  maxWeightRestriction                          Int?
  continentRestriction                          CircleContinentRestriction[]
  willingToRelocateRestriction                  CircleRelocationRestriction[]
  childrenRestriction                           CircleChildrenRestriction[]
  ethnicityRestriction                          CircleEthnicityRestriction[]
  drinkingRestriction                           CircleDrinkingRestriction[]
  consumablesRestriction                        CircleConsumablesRestriction[]
  politicalBeliefsRestriction                   CirclePoliticalBeliefsRestriction[]
  levelOfEducationRestriction                   CircleLevelOfEducationRestriction[]
  purityRestriction                             CirclePurityRestriction[]
  onlyLookingForTraditionalHouseholdRestriction CircleTraditionalRestriction[]
  incomeRestriction                             CircleIncomeRestriction[]
  maritalStatusRestriction                      CircleMaritalStatusRestriction[]
  activityRestriction                           CircleActivityRestriction[]
  religionRestriction                           CircleReligionRestriction[]
  users                                         UserCircle[]

  @@index([name])
}

model CircleContinentRestriction {
  id          String    @id @default(uuid())
  circleName  String
  circle      Circle    @relation(fields: [circleName], references: [name])
  restriction Continent

  @@index([circleName])
}

model CircleSexRestriction {
  id          String @id @default(uuid())
  circleName  String
  circle      Circle @relation(fields: [circleName], references: [name])
  restriction Gender

  @@index([circleName])
}

model CircleRelocationRestriction {
  id          String         @id @default(uuid())
  circleName  String
  circle      Circle         @relation(fields: [circleName], references: [name])
  restriction YesNoOrUnknown

  @@index([circleName])
}

model CircleChildrenRestriction {
  id          String   @id @default(uuid())
  circleName  String
  circle      Circle   @relation(fields: [circleName], references: [name])
  restriction Children

  @@index([circleName])
}

model CircleEthnicityRestriction {
  id          String    @id @default(uuid())
  circleName  String
  circle      Circle    @relation(fields: [circleName], references: [name])
  restriction Ethnicity

  @@index([circleName])
}

model CircleDrinkingRestriction {
  id          String   @id @default(uuid())
  circleName  String
  circle      Circle   @relation(fields: [circleName], references: [name])
  restriction Drinking

  @@index([circleName])
}

model CircleConsumablesRestriction {
  id          String      @id @default(uuid())
  circleName  String
  circle      Circle      @relation(fields: [circleName], references: [name])
  restriction Consumables

  @@index([circleName])
}

model CirclePoliticalBeliefsRestriction {
  id          String           @id @default(uuid())
  circleName  String
  circle      Circle           @relation(fields: [circleName], references: [name])
  restriction PoliticalBeliefs

  @@index([circleName])
}

model CircleLevelOfEducationRestriction {
  id          String           @id @default(uuid())
  circleName  String
  circle      Circle           @relation(fields: [circleName], references: [name])
  restriction LevelOfEducation

  @@index([circleName])
}

model CirclePurityRestriction {
  id          String           @id @default(uuid())
  circleName  String
  circle      Circle           @relation(fields: [circleName], references: [name])
  restriction Purity

  @@index([circleName])
}

model CircleTraditionalRestriction {
  id          String         @id @default(uuid())
  circleName  String
  circle      Circle         @relation(fields: [circleName], references: [name])
  restriction YesNoOrUnknown

  @@index([circleName])
}

model CircleIncomeRestriction {
  id          String @id @default(uuid())
  circleName  String
  circle      Circle @relation(fields: [circleName], references: [name])
  restriction Income

  @@index([circleName])
}

model CircleMaritalStatusRestriction {
  id          String        @id @default(uuid())
  circleName  String
  circle      Circle        @relation(fields: [circleName], references: [name])
  restriction MaritalStatus

  @@index([circleName])
}

model CircleActivityRestriction {
  id          String   @id @default(uuid())
  circleName  String
  circle      Circle   @relation(fields: [circleName], references: [name])
  restriction Activity

  @@index([circleName])
}

model CircleReligionRestriction {
  id          String   @id @default(uuid())
  circleName  String
  circle      Circle   @relation(fields: [circleName], references: [name])
  restriction Religion

  @@index([circleName])
}

model User {
  id                  String       @id @default(uuid())
  email               String       @unique
  password            String
  profile             UserProfile  @relation(fields: [userProfileUsername], references: [username])
  circles             UserCircle[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  userProfileUsername String       @unique
  userCircleUsername  String       @unique

  @@index([userProfileUsername])
}
